# Enable the live Slack integration tests.
# Accepted truthy values: 1, true, TRUE, yes, on
RUN_LIVE_SLACK_TESTS=false

# Bot token from Slack OAuth & Permissions (required for live tests)
SLACK_BOT_TOKEN=

# Channel id used for live integration tests (required for live channel tests)
SLACK_TEST_CHANNEL_ID=

# Optional: user id used for DM + ephemeral coverage
SLACK_TEST_USER_ID=

# Optional: reaction name used by the live reaction test
SLACK_TEST_REACTION=wave

# Optional: signing secret for webhook verification tests / local ingress work
SLACK_SIGNING_SECRET=

# Optional: app-level token for Socket Mode (`xapp-...`)
SLACK_APP_TOKEN=
